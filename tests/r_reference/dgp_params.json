{
  "description": "Python↔R数值一致性验证的共享DGP参数",
  "note": "这些参数必须与R包的simulate_contdid_data()默认值保持一致",
  "consistency_threshold": 3.0,
  "consistency_metric": "max|bias/SE|",
  "scenarios": {
    "SIM-001-null-dose": {
      "description": "零效应基准（ATT=0, ACRT=0）",
      "n": 5000,
      "num_time_periods": 4,
      "num_groups": 4,
      "pg": [0.25, 0.25, 0.25],
      "pu": 0.25,
      "dose_linear_effect": 0.0,
      "dose_quadratic_effect": 0.0,
      "seed": 12345,
      "true_att_fn": "0",
      "true_acrt_fn": "0"
    },
    "SIM-002-linear-dose": {
      "description": "线性剂量效应（ATT(d)=d, ACRT(d)=1）",
      "n": 5000,
      "num_time_periods": 4,
      "num_groups": 4,
      "pg": [0.25, 0.25, 0.25],
      "pu": 0.25,
      "dose_linear_effect": 1.0,
      "dose_quadratic_effect": 0.0,
      "seed": 23456,
      "true_att_fn": "dose_linear_effect * d",
      "true_acrt_fn": "dose_linear_effect"
    },
    "SIM-003-quadratic-dose": {
      "description": "二次剂量效应（ATT(d)=d^2, ACRT(d)=2d）",
      "n": 5000,
      "num_time_periods": 4,
      "num_groups": 4,
      "pg": [0.25, 0.25, 0.25],
      "pu": 0.25,
      "dose_linear_effect": 0.0,
      "dose_quadratic_effect": 1.0,
      "seed": 34567,
      "true_att_fn": "dose_quadratic_effect * d^2",
      "true_acrt_fn": "2 * dose_quadratic_effect * d"
    },
    "SIM-006-linear-quadratic": {
      "description": "线性+二次组合效应（ATT(d)=2d+0.5d^2, ACRT(d)=2+d）",
      "n": 5000,
      "num_time_periods": 4,
      "num_groups": 4,
      "pg": [0.25, 0.25, 0.25],
      "pu": 0.25,
      "dose_linear_effect": 2.0,
      "dose_quadratic_effect": 0.5,
      "seed": 45678,
      "true_att_fn": "dose_linear_effect * d + dose_quadratic_effect * d^2",
      "true_acrt_fn": "dose_linear_effect + 2 * dose_quadratic_effect * d"
    }
  },
  "two_period_scenarios": {
    "SIM-TP-linear": {
      "description": "两期线性效应（Python↔R直接对比，避免staggered聚合差异）",
      "n": 5000,
      "num_time_periods": 2,
      "num_groups": 2,
      "pg": [0.75],
      "pu": 0.25,
      "dose_linear_effect": 1.0,
      "dose_quadratic_effect": 0.0,
      "seed": 56789,
      "true_att_fn": "dose_linear_effect * d",
      "true_acrt_fn": "dose_linear_effect"
    },
    "SIM-TP-quadratic": {
      "description": "两期二次效应",
      "n": 5000,
      "num_time_periods": 2,
      "num_groups": 2,
      "pg": [0.75],
      "pu": 0.25,
      "dose_linear_effect": 0.0,
      "dose_quadratic_effect": 1.0,
      "seed": 67890,
      "true_att_fn": "dose_quadratic_effect * d^2",
      "true_acrt_fn": "2 * dose_quadratic_effect * d"
    },
    "SIM-TP-combined": {
      "description": "两期组合效应",
      "n": 5000,
      "num_time_periods": 2,
      "num_groups": 2,
      "pg": [0.75],
      "pu": 0.25,
      "dose_linear_effect": 2.0,
      "dose_quadratic_effect": 0.5,
      "seed": 78901,
      "true_att_fn": "dose_linear_effect * d + dose_quadratic_effect * d^2",
      "true_acrt_fn": "dose_linear_effect + 2 * dose_quadratic_effect * d"
    }
  },
  "estimation_params": {
    "parametric": {
      "degree": 3,
      "num_knots": 0,
      "biters": 1000,
      "alp": 0.05
    },
    "cck": {
      "degree": 3,
      "num_knots": 0,
      "biters": 1000,
      "alp": 0.05
    }
  }
}
